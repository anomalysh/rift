# syntax=docker/dockerfile:1

# Builds the rift CLI into a single self-contained executable with Bun's
# compiler. Build context is the repo root; the CLI sources live under projects/cli/.
#   docker build -f deploy/Dockerfile.cli -t rift-cli:local .

# --- build ------------------------------------------------------------------
# Pinned to the mise.toml bun (tools/check-versions.sh gates it): a floating
# `oven/bun:1` could ship a CLI built on a different Bun than CI tested.
FROM oven/bun:1.3.14 AS build
WORKDIR /src

COPY projects/cli/ ./
RUN bun install

# `bun build --compile` bakes the Bun runtime and all sources into one binary.
# Assumes the CLI entrypoint is projects/cli/src/index.ts (adjust if the CLI differs).
RUN bun build ./src/index.ts --compile --minify --outfile /out/rift

# --- runtime ----------------------------------------------------------------
FROM debian:12-slim AS runtime
RUN useradd -r -u 10001 rift
COPY --from=build /out/rift /usr/local/bin/rift
USER rift

# OCI image metadata. The publish workflow (and tools/publish-images.sh) inject
# real values via --build-arg; the defaults keep a plain `docker build` emitting
# a valid, if generic, labelled image.
ARG IMAGE_SOURCE="https://github.com/anomalysh/rift"
ARG IMAGE_REVISION=""
ARG IMAGE_VERSION="dev"
ARG IMAGE_CREATED=""
ARG IMAGE_LICENSES="NOASSERTION"
ARG IMAGE_TITLE="rift-cli"
ARG IMAGE_DESCRIPTION="rift CLI tunnel agent"
LABEL org.opencontainers.image.source="$IMAGE_SOURCE" \
      org.opencontainers.image.revision="$IMAGE_REVISION" \
      org.opencontainers.image.version="$IMAGE_VERSION" \
      org.opencontainers.image.created="$IMAGE_CREATED" \
      org.opencontainers.image.licenses="$IMAGE_LICENSES" \
      org.opencontainers.image.title="$IMAGE_TITLE" \
      org.opencontainers.image.description="$IMAGE_DESCRIPTION"

ENTRYPOINT ["rift"]
