# rift production reverse proxy.
#
# Wildcard TLS via DNS-01 would need DNS-provider API credentials we do not
# have, so certificates are issued ON DEMAND over HTTP-01 / TLS-ALPN. This only
# works because the wildcard A/AAAA records already point every label under
# RIFT_BASE_DOMAIN at this host, so ACME can validate each subdomain the first
# time it is requested. Everything host/domain-specific comes from {$VAR}
# placeholders (supplied by the caddy container's environment), never literals.
{
	# ACME account contact; Let's Encrypt uses it for expiry warnings.
	email {$RIFT_ACME_EMAIL}

	# On-demand TLS mints a certificate the first time an unrecognised SNI
	# arrives. WITHOUT an `ask` endpoint this is an OPEN CERTIFICATE-ISSUANCE
	# RELAY: anyone who points a hostname at this IP could make us request
	# certificates on their behalf and exhaust our Let's Encrypt rate limit.
	# `ask` is therefore MANDATORY. Caddy GETs this URL with `?domain=<sni>`
	# appended (QueryParamDomain); riftd replies 200 to authorise issuance (the
	# subdomain maps to a live tunnel) or non-200 to refuse. The path is the
	# RouteTLSAsk constant from server/internal/config/keys.go.
	on_demand_tls {
		ask http://{$RIFT_UPSTREAM_HOST:riftd}:{$RIFT_INGRESS_PORT:8080}/internal/tls-ask
	}

	# Long-lived streams are the entire point of this service. Any non-zero
	# read/write/idle timeout here would silently sever a WebSocket tunnel or a
	# slow streamed response, so every server timeout is disabled. Liveness is
	# enforced by riftd's own application-level heartbeat, not by the proxy.
	servers {
		timeouts {
			read_body 0
			read_header 0
			write 0
			idle 0
		}
	}
}

# --- Public tunnel traffic: https://<subdomain>.RIFT_BASE_DOMAIN ------------
*.{$RIFT_BASE_DOMAIN} {
	tls {
		on_demand
	}

	# NO Strict-Transport-Security on the wildcard. Each tunnel is an
	# untrusted, user-controlled subdomain of RIFT_BASE_DOMAIN. An HSTS header
	# served from one malicious tunnel (especially with includeSubDomains)
	# would be cached by the browser against the PARENT domain and could brick
	# unrelated sibling subdomains. HSTS belongs only on hostnames we fully
	# control, never here.

	reverse_proxy {$RIFT_UPSTREAM_HOST:riftd}:{$RIFT_INGRESS_PORT:8080}
}

# --- The base domain itself: https://RIFT_BASE_DOMAIN ------------------------
# A wildcard certificate covers *.example.com but NOT example.com, and the
# wildcard site block above does not match the apex either. Without this block
# the apex has no certificate and anyone who trims a subdomain off a tunnel URL
# gets a TLS error rather than an answer. riftd replies with a plain 404 saying
# the host is not a tunnel, which is the truthful response.
{$RIFT_BASE_DOMAIN} {
	tls {
		on_demand
	}
	reverse_proxy {$RIFT_UPSTREAM_HOST:riftd}:{$RIFT_INGRESS_PORT:8080}
}

# --- Agent gateway: wss://RIFT_GATEWAY_HOSTNAME -----------------------------
# The CLI dials the gateway over TLS from the public internet.
{$RIFT_GATEWAY_HOSTNAME} {
	# on_demand is REQUIRED here, even though this is an exact-match site with
	# a hostname we control, and omitting it silently yields NO CERTIFICATE AT
	# ALL. RIFT_GATEWAY_HOSTNAME normally sits under RIFT_BASE_DOMAIN, so it is
	# shadowed by the wildcard's on-demand automation policy. In that state
	# Caddy skips obtaining a managed certificate at start-up, yet the
	# handshake resolves the exact (non-on-demand) policy and so refuses to
	# obtain one lazily either. The name falls between the two paths and every
	# TLS connection fails with "no certificate available".
	#
	# Marking it on_demand puts it on one consistent path: riftd's `ask`
	# endpoint authorises this exact hostname (RIFT_GATEWAY_HOSTNAME is read by
	# the server for precisely that purpose), so the certificate is issued on
	# the first dial and renewed normally thereafter.
	tls {
		on_demand
	}

	# Caddy upgrades WebSockets automatically. flush_interval -1 disables
	# response buffering so the upgrade and every subsequent frame stream
	# through immediately; together with the disabled server timeouts above a
	# tunnel can stay connected indefinitely.
	reverse_proxy {$RIFT_UPSTREAM_HOST:riftd}:{$RIFT_GATEWAY_PORT:8081} {
		flush_interval -1
	}
}

# --- Admin API is deliberately NOT exposed ----------------------------------
# riftd's admin listener (RIFT_ADMIN_ADDR, default :8082) manages tokens and
# reservations. It is intentionally not proxied by any site block here, and its
# port is never published on the host. Reach it only from the VPS itself or
# over an SSH tunnel. Exposing it publicly would put token minting one weak
# credential away from a full takeover.
