# rift reverse proxy.
#
# How certificates are obtained is chosen by RIFT_TLS_MODE, which selects a
# pair of snippets under modes/:
#
#   dns01     one wildcard certificate via the DNS-01 challenge. Every
#             subdomain is covered, so an unknown tunnel gets a readable 404
#             over valid TLS. Needs a DNS provider (RIFT_ACME_DNS_PROVIDER)
#             and a Caddy image built with that provider's plugin.
#   http01    a certificate per hostname, minted on first contact via HTTP-01
#             and gated by riftd's ask endpoint. No DNS credentials needed,
#             but a hostname that never served a tunnel has no certificate and
#             so cannot complete a handshake at all.
#   self      a certificate and key the operator supplies.
#   internal  Caddy's own CA. Nothing publicly trusted. Local dev and e2e.
#
# riftd validates RIFT_TLS_MODE at boot and refuses to start on a bad or
# (in production) absent value, so this file can assume the mode is sane.
#
# Everything host-specific comes from {$VAR} placeholders supplied by the
# container's environment. There are no literals here.
{
	# ACME account contact. Ignored by the self and internal modes.
	email {$RIFT_ACME_EMAIL}

	# Which certificate authority the ACME modes talk to. `public` is Let's
	# Encrypt; `internal-ca` points at your own ACME server. Ignored by the
	# self and internal modes, which never speak ACME.
	import /etc/caddy/acme/{$RIFT_ACME_CA_PROFILE:public}.caddy

	import /etc/caddy/modes/{$RIFT_TLS_MODE}.global.caddy

	# Long-lived streams are the entire point of this service. Any non-zero
	# read/write/idle timeout here would silently sever a WebSocket tunnel or a
	# slow streamed response, so every server timeout is disabled. Liveness is
	# enforced by riftd's own application-level heartbeat, not by the proxy.
	servers {
		timeouts {
			read_body 0
			read_header 0
			write 0
			idle 0
		}
	}
}

# The per-site half of the TLS mode. Imported by every site block below so that
# no site can accidentally end up on a different certificate path than the
# others -- which is exactly the bug that once left the gateway hostname with
# no certificate at all.
(rift_site_tls) {
	import /etc/caddy/modes/{$RIFT_TLS_MODE}.site.caddy
}

# --- Public tunnel traffic, and the base domain itself ----------------------
#
# The apex is served by the same block. A wildcard certificate covers
# *.example.com but NOT example.com, and a `*.example.com` site block does not
# match the apex either, so naming both here is what keeps the bare domain from
# having no certificate. riftd answers it with a plain 404: it is not a tunnel.
#
# NO Strict-Transport-Security. Each tunnel is an untrusted, user-controlled
# subdomain. An HSTS header served from one malicious tunnel (especially with
# includeSubDomains) would be cached by the browser against the PARENT domain
# and could brick unrelated sibling subdomains. HSTS belongs only on hostnames
# we fully control, never here.
*.{$RIFT_BASE_DOMAIN}, {$RIFT_BASE_DOMAIN} {
	import rift_site_tls
	reverse_proxy {$RIFT_UPSTREAM_HOST:riftd}:{$RIFT_INGRESS_PORT:8080}
}

# --- Agent gateway: wss://RIFT_GATEWAY_HOSTNAME -----------------------------
{$RIFT_GATEWAY_HOSTNAME} {
	import rift_site_tls

	# Caddy upgrades WebSockets automatically. flush_interval -1 disables
	# response buffering so the upgrade and every subsequent frame stream
	# through immediately; together with the disabled server timeouts above a
	# tunnel can stay connected indefinitely.
	reverse_proxy {$RIFT_UPSTREAM_HOST:riftd}:{$RIFT_GATEWAY_PORT:8081} {
		flush_interval -1
	}
}

# --- Admin API is deliberately NOT exposed ----------------------------------
# riftd's admin listener (RIFT_ADMIN_ADDR, default :8082) manages tokens and
# reservations. It is intentionally not proxied by any site block here, and its
# port is never published on the host. Reach it only from the host itself or
# over an SSH tunnel. Exposing it publicly would put token minting one weak
# credential away from a full takeover.
