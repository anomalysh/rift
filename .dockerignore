# Keep the build context small and reproducible. Image builds COPY only the
# sources they need; everything below is either huge, machine-specific, or a
# secret, and must never be sent to the daemon.
.git
.github
.claude
dist
node_modules
**/node_modules
projects/cli/node_modules
projects/manual/node_modules
.env
**/.env
*.log
tools/.ssh
projects/server/riftd
