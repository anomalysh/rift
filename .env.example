# rift environment configuration — EXAMPLE / TEMPLATE
#
# Copy to an untracked .env and fill in the blanks:
#     cp .env.example .env
#
# ##########################################################################
# #  THIS FILE IS COMMITTED TO GIT AND MUST NEVER CONTAIN A REAL           #
# #  CREDENTIAL. Every secret below is an EMPTY placeholder. Put real      #
# #  values only in your untracked .env, never here.                       #
# ##########################################################################
#
# "Default:" notes mirror server/internal/config/defaults.go. Vars marked
# REQUIRED have no default: the server refuses to boot without them. Vars that
# start commented out (#VAR=) are optional overrides shown for reference.
# Values are quoted where they contain URL/DSN special characters so the same
# file can be read by Docker Compose AND `source`d by the Makefile deploy
# targets.

# ============================================================================
#  Server settings — read by riftd (names from server/internal/config/keys.go)
# ============================================================================

# --- Core -------------------------------------------------------------------
# "development" or "production".  Default: development
RIFT_ENV=development
# Stable node identity for restart/multi-node reclaim.  Default: auto-generated
#RIFT_NODE_ID=

# --- Logging ----------------------------------------------------------------
# debug | info | warn | error.  Default: info
RIFT_LOG_LEVEL=info
# json | text.  Default: json
RIFT_LOG_FORMAT=json

# --- Public ingress (proxied *.RIFT_BASE_DOMAIN traffic) --------------------
# Listen address.  Default: :8080
RIFT_INGRESS_ADDR=:8080
# Default: 30s
RIFT_INGRESS_READ_TIMEOUT=30s
# 0 = no write deadline (required so long streamed responses are not cut off).  Default: 0
RIFT_INGRESS_WRITE_TIMEOUT=0
# Default: 120s
RIFT_INGRESS_IDLE_TIMEOUT=120s
# Default: 1048576 (1 MiB)
RIFT_INGRESS_MAX_HEADER_BYTES=1048576
# Comma-separated peers whose X-Forwarded-For is trusted (in prod this is Caddy).
# Empty = trust nobody, use the socket peer.  Default: (empty)
#RIFT_INGRESS_TRUSTED_PROXY_IPS=

# --- Agent gateway (WebSocket endpoint the CLI dials) -----------------------
# Default: :8081
RIFT_GATEWAY_ADDR=:8081
# WebSocket path.  Default: /tunnel
RIFT_GATEWAY_PATH=/tunnel
# Default: 10s
RIFT_GATEWAY_HANDSHAKE_TIMEOUT=10s
# Default: 30s
RIFT_GATEWAY_WRITE_TIMEOUT=30s
# Comma-separated browser origins. Agents send no Origin, so empty is correct.  Default: (empty)
#RIFT_GATEWAY_ALLOWED_ORIGINS=

# --- Admin API (token & reservation management; never exposed publicly) -----
# Default: true
RIFT_ADMIN_ENABLED=true
# Default: :8082
RIFT_ADMIN_ADDR=:8082
# REQUIRED when admin enabled; must be >=32 chars in production.
# SECRET — leave empty here, set it only in your untracked .env.
RIFT_ADMIN_TOKEN=

# --- Postgres ---------------------------------------------------------------
# REQUIRED. Connection string. The password component is a SECRET — leave this
# empty here and set the full DSN in your untracked .env, e.g.
#   RIFT_POSTGRES_DSN="postgres://rift:REAL_PASSWORD@db-host:5432/rift?sslmode=require"
# Local dev: deploy/docker-compose.yml supplies a working throwaway DSN, so you
# can leave this empty locally.
RIFT_POSTGRES_DSN=
# Default: 10
RIFT_POSTGRES_MAX_CONNS=10
# Default: 2
RIFT_POSTGRES_MIN_CONNS=2
# Default: 10s
RIFT_POSTGRES_CONNECT_TIMEOUT=10s
# Default: true
RIFT_POSTGRES_MIGRATE_ON_START=true

# --- Redis (optional; enables multi-node routing) ---------------------------
# Default: false
RIFT_REDIS_ENABLED=false
# Default: 127.0.0.1:6379  (the compose redis service is reachable as redis:6379)
RIFT_REDIS_ADDR=127.0.0.1:6379
# SECRET if your Redis requires auth — set only in your untracked .env.  Default: (empty)
RIFT_REDIS_PASSWORD=
# Default: 0
RIFT_REDIS_DB=0
# Default: rift:
RIFT_REDIS_PREFIX=rift:

# --- Cluster / peer forwarding ----------------------------------------------
# SECRET. Authenticates node-to-node request forwarding on the internal proxy
# route. REQUIRED (>=32 chars) only when RIFT_REDIS_ENABLED=true; leave empty
# for single-node, and set it only in your untracked .env otherwise.  Default: (empty)
RIFT_PEER_SECRET=

# --- Tunnel behaviour -------------------------------------------------------
# REQUIRED. Wildcard base domain for tunnel hostnames.
RIFT_BASE_DOMAIN=rift.anomaly.sh
# http | https.  Default: https
RIFT_PUBLIC_SCHEME=https
# How peer nodes reach this node's internal proxy. Required only when
# RIFT_REDIS_ENABLED=true.  Default: (empty)
#RIFT_NODE_ADVERTISE_URL=
# Default: 15s
RIFT_HEARTBEAT_INTERVAL=15s
# Must exceed RIFT_HEARTBEAT_INTERVAL.  Default: 45s
RIFT_HEARTBEAT_TIMEOUT=45s
# Default: 30s
RIFT_REAPER_INTERVAL=30s

# How often a live tunnel re-checks that its token is still valid. Revoking or
# expiring a token closes the tunnels it already opened within this interval,
# so this is the upper bound on how long a leaked token keeps serving traffic
# after you revoke it. Lower it to react faster, at the cost of one database
# read per tunnel per interval.
# Default: 30s
RIFT_TOKEN_REVALIDATE_INTERVAL=30s
# Default: 60s
RIFT_REQUEST_TIMEOUT=60s
# 0 = unlimited.  Default: 33554432 (32 MiB)
RIFT_MAX_REQUEST_BODY_BYTES=33554432
# Default: 5
RIFT_MAX_TUNNELS_PER_TOKEN=5
# Default: 32
RIFT_STREAM_BUFFER_SIZE=32

# --- Subdomain rules --------------------------------------------------------
# Default: 3
RIFT_SUBDOMAIN_MIN_LENGTH=3
# Default: 63
RIFT_SUBDOMAIN_MAX_LENGTH=63
# Default: ^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$
RIFT_SUBDOMAIN_PATTERN='^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$'
# Comma-separated extra reserved labels, added to the built-in blocklist.  Default: (built-in)
#RIFT_SUBDOMAIN_BLOCKLIST=
# Default: 10
RIFT_SUBDOMAIN_GENERATED_LENGTH=10
# Default: abcdefghjkmnpqrstuvwxyz23456789
RIFT_SUBDOMAIN_GENERATED_ALPHABET=abcdefghjkmnpqrstuvwxyz23456789

# ============================================================================
#  Deployment-only settings — riftd itself never reads these. They drive Caddy,
#  the tools/ scripts, and the local compose files.
# ============================================================================

# --- Caddy / TLS (production reverse proxy) ---------------------------------
# ACME account contact for Let's Encrypt (expiry notices). Not a secret.
# REQUIRED for the production Caddy: an empty value makes Caddy fail to start.
RIFT_ACME_EMAIL=
# Dedicated public hostname for the agent gateway; the CLI dials
# wss://<this>/tunnel. Must resolve to the VPS.
# The public hostname agents dial (wss://...). Read by BOTH Caddy and riftd:
# riftd's TLS-ask endpoint authorises a certificate for exactly this name, so a
# mismatch between this value and the Caddyfile means the gateway gets no
# certificate and every agent connection fails at the TLS handshake.
#
# WARNING: this hostname's first label ("gateway") MUST also appear in
# RIFT_SUBDOMAIN_BLOCKLIST, or an agent could claim it as a tunnel subdomain.
# Caddy matches this exact host before the wildcard, so such a tunnel would be
# silently unroutable -- and worse, it would hold a subdomain that looks
# official. "gateway" is in the built-in blocklist; if you change this value,
# add its label to RIFT_SUBDOMAIN_BLOCKLIST.
RIFT_GATEWAY_HOSTNAME=gateway.rift.anomaly.sh
# Compose service name Caddy proxies to.  Default: riftd
RIFT_UPSTREAM_HOST=riftd
# Upstream ports Caddy dials. MUST match the port component of
# RIFT_INGRESS_ADDR / RIFT_GATEWAY_ADDR above.
RIFT_INGRESS_PORT=8080
RIFT_GATEWAY_PORT=8081

# --- VPS access (tools/) ----------------------------------------------------
# REQUIRED for deploy/provision. VPS IP or hostname.
RIFT_VPS_HOST=172.105.209.110
# Default: root
RIFT_VPS_USER=root
# Default: 22
RIFT_VPS_PORT=22
# SECRET. Used ONLY to bootstrap key auth (make provision-key). Leave empty here.
# After provisioning: disable password auth on the VPS AND rotate this password;
# key auth (tools/.ssh/id_ed25519) is used for every deploy thereafter.
RIFT_VPS_PASSWORD=

# --- Admin tooling (tools/mint-token.sh) ------------------------------------
# Admin API base URL (not public — use localhost on the VPS or an SSH tunnel).
# Default: http://127.0.0.1:8082
RIFT_ADMIN_URL=http://127.0.0.1:8082

# --- Local dev Postgres container (deploy/docker-compose.yml only) ----------
# Throwaway credentials for the LOCAL dev database container — NOT production.
POSTGRES_USER=rift
POSTGRES_PASSWORD=rift
POSTGRES_DB=rift
