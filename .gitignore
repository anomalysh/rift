# Root-level ignores shared across the whole repo. Stack-specific ignores live in
# each project's own .gitignore (projects/*/.gitignore), sourced from that
# stack's canonical default (bun init, github/gitignore Go, the Astro template).

# Release artifacts (tools/release.sh -> dist/release/<version>)
/dist/

# Generated docs — the man page and shell completions are regenerated from the
# CLI spec (mise run gen-docs / the release pipeline); never committed.
/packaging/

# Local scratchpad for research/design notes — never committed.
/scratchpad/

# Env & secrets (repo-wide; never commit real values)
.env
.env.*
!.env.example
*.pem
*.key
!deploy/**/*.example
tools/.ssh/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Deploy runtime state
deploy/caddy/data/
deploy/caddy/config/

# Provisioning / pipeline state (records instance ids and IPs)
.rift/

# Backup artifacts — dumps hold token hashes, archives hold TLS keys; never commit
/backups/
rift-*-db.dump
rift-*-caddy.tar.gz
