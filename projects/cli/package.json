{
  "name": "rift",
  "version": "0.2.0",
  "description": "Fully-typed Bun/TypeScript single-binary ngrok-style tunnel agent.",
  "private": true,
  "license": "UNLICENSED",
  "author": "David Mydlarz",
  "type": "module",
  "homepage": "https://github.com/anomalysh/rift",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalysh/rift.git",
    "directory": "projects/cli"
  },
  "bugs": {
    "url": "https://github.com/anomalysh/rift/issues"
  },
  "keywords": [
    "tunnel",
    "ngrok",
    "reverse-proxy",
    "websocket",
    "self-hosted",
    "cli",
    "bun"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "rift": "./dist/rift"
  },
  "scripts": {
    "build": "bun build --compile --minify --sourcemap ./src/index.ts --outfile dist/rift",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "check": "bun run lint && bun run typecheck && bun test"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "7.0.2"
  }
}
